# Example environment variables for AziAuth
# Copy this file to .env.local and fill in your actual values

# ============================================
# CLERK AUTHENTICATION
# ============================================

# Get from: Clerk Dashboard > API Keys
# Format: pk_test_xxxxx or pk_live_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Get from: Clerk Dashboard > API Keys
# Format: sk_test_xxxxx or sk_live_xxxxx
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ============================================
# CLERK URLS (Pre-configured, modify if needed)
# ============================================

# URL where user is redirected after signing in
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# URL where user is redirected after signing up
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# URL where user is redirected after successful sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# URL where user is redirected after successful sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# OPTIONAL: CUSTOM CONFIGURATION
# ============================================

# Application name (used in titles and branding)
# NEXT_PUBLIC_APP_NAME=AziAuth

# Application domain (for production)
# NEXT_PUBLIC_APP_URL=https://aziauth.example.com

# Enable debug mode (for development)
# DEBUG=true

# ============================================
# OAUTH PROVIDER CREDENTIALS (Optional)
# ============================================

# Google OAuth (if using Google Sign-In)
# Configure in Clerk Dashboard > Social Connections > Google
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# GitHub OAuth (if using GitHub Sign-In)
# Configure in Clerk Dashboard > Social Connections > GitHub
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# ============================================
# DATABASE (Optional - for future use)
# ============================================

# PostgreSQL connection string (when adding database)
# DATABASE_URL=postgresql://user:password@localhost:5432/aziauth

# ============================================
# NOTES
# ============================================

# 1. NEVER commit this file to version control if it contains real keys
# 2. Use .gitignore to prevent accidental commits (already configured)
# 3. Restart the development server after changing env variables
# 4. For production, use Vercel Environment Variables instead
# 5. Keep NEXT_PUBLIC_ prefixed variables for client-side access
# 6. All other variables are server-side only
